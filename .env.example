# Grant Writing Platform - Environment Configuration
# Copy this file to .env and update values for your deployment

# Required: Secret key for Flask sessions
SECRET_KEY=your-secret-key-change-in-production

# Optional: OpenAI API key for AI-powered grant generation
OPENAI_API_KEY=

# Database path (defaults to SQLite)
DATABASE_URL=sqlite:///grant_platform.db

# Environment (development, production)
FLASK_ENV=production